<% const activeAdminPage = typeof activePage !== 'undefined' ? activePage : ''; %>

<button class="menu-toggle" id="menuToggle">
    <i class="fas fa-bars"></i>
</button>

<!-- Sidebar -->
<div class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <h3><i class="fas fa-hotel me-2"></i>Hotelier</h3>
        <p>Admin Dashboard</p>
    </div>
    <div class="sidebar-menu">
        <a href="/admin/index" class="menu-item <%= activeAdminPage === 'dashboard' ? 'active' : '' %>">
            <i class="fas fa-tachometer-alt"></i>
            <span>Dashboard</span>
        </a>
        <a href="/admin/rooms" class="menu-item <%= activeAdminPage === 'rooms' ? 'active' : '' %>">
            <i class="fas fa-bed"></i>
            <span>Manage Rooms</span>
        </a>
        <a href="/admin/bookings" class="menu-item <%= activeAdminPage === 'bookings' ? 'active' : '' %>">
            <i class="fas fa-calendar-check"></i>
            <span>Manage Bookings</span>
        </a>
        <a href="/admin/users" class="menu-item <%= activeAdminPage === 'users' ? 'active' : '' %>">
            <i class="fas fa-users"></i>
            <span>Manage Users</span>
        </a>
        <a href="/admin/reviews" class="menu-item <%= activeAdminPage === 'reviews' ? 'active' : '' %>">
            <i class="fas fa-star"></i>
            <span>Manage Reviews</span>
        </a>
        <a href="/admin/contacts" class="menu-item <%= activeAdminPage === 'contacts' ? 'active' : '' %>">
            <i class="fas fa-envelope"></i>
            <span>Contact Messages</span>
        </a>
        <hr class="mx-3 my-3" style="border-color: rgba(255,255,255,0.1);">
        <a href="#" class="menu-item" id="logoutBtn">
            <i class="fas fa-sign-out-alt"></i>
            <span>Logout</span>
        </a>
        <a href="/" class="menu-item">
            <i class="fas fa-globe"></i>
            <span>View Website</span>
        </a>
    </div>
</div>
