<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Hotelier - My Profile</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <link href="/img/favicon.ico" rel="icon">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/lib/animate/animate.min.css" rel="stylesheet">
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet">
</head>

<body>
    <div class="container-xxl bg-white p-0">
        <%- include('../partials/header', { currentPage: 'profile' }) %>

        <div class="container-fluid page-header mb-5 p-0" style="background-image: url(img/carousel-1.jpg);">
            <div class="container-fluid page-header-inner py-5">
                <div class="container text-center pb-5">
                    <h1 class="display-3 text-white mb-3 animated slideInDown">My Profile</h1>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb justify-content-center text-uppercase">
                            <li class="breadcrumb-item"><a href="/">Home</a></li>
                            <li class="breadcrumb-item text-white active" aria-current="page">Profile</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>

        <div class="container-xxl py-5">
            <div class="container">
                <div class="row g-4">
                    <div class="col-lg-4">
                        <div class="bg-light rounded p-4 h-100">
                            <div class="text-center mb-4">
                                <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 90px; height: 90px;">
                                    <span class="h1 mb-0" id="profileInitial">U</span>
                                </div>
                                <h4 class="mb-1" id="profileName">Guest User</h4>
                                <p class="text-muted mb-0" id="profileRole">Customer</p>
                            </div>
                            <div class="border-top pt-4">
                                <p class="mb-3"><i class="fa fa-envelope text-primary me-2"></i><span id="profileEmail">-</span></p>
                                <p class="mb-0"><i class="fa fa-phone-alt text-primary me-2"></i><span id="profilePhone">-</span></p>
                            </div>
                            <button class="btn btn-danger w-100 mt-4" id="profileLogoutBtn">
                                <i class="fa fa-sign-out-alt me-2"></i>Logout
                            </button>
                        </div>
                    </div>

                    <div class="col-lg-8">
                        <div class="bg-light rounded p-4 mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h4 class="mb-0">Account Overview</h4>
                                <a href="/room" class="btn btn-primary btn-sm">Browse Rooms</a>
                            </div>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="bg-white rounded p-3">
                                        <p class="text-muted mb-1">Total Bookings</p>
                                        <h3 class="mb-0" id="bookingCount">0</h3>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="bg-white rounded p-3">
                                        <p class="text-muted mb-1">Upcoming</p>
                                        <h3 class="mb-0" id="upcomingCount">0</h3>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="bg-white rounded p-3">
                                        <p class="text-muted mb-1">Cancelled</p>
                                        <h3 class="mb-0" id="cancelledCount">0</h3>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="bg-light rounded p-4">
                            <h4 class="mb-4">My Bookings</h4>
                            <div class="table-responsive">
                                <table class="table table-hover bg-white mb-0">
                                    <thead>
                                        <tr>
                                            <th>Booking</th>
                                            <th>Room</th>
                                            <th>Check In</th>
                                            <th>Check Out</th>
                                            <th>Total</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody id="profileBookings">
                                        <tr>
                                            <td colspan="6" class="text-center text-muted py-4">Loading bookings...</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <%- include('../partials/footer') %>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="/js/config.js"></script>
    <script src="/js/api.js"></script>
    <script src="/js/auth.js"></script>
    <script>
        function formatDate(value) {
            return value ? new Date(value).toISOString().split('T')[0] : '-';
        }

        function statusBadge(status) {
            const normalized = String(status || 'pending').toLowerCase();
            const badgeClass = normalized === 'cancelled' ? 'danger' : normalized === 'confirmed' ? 'success' : 'warning';
            return `<span class="badge bg-${badgeClass} text-uppercase">${normalized}</span>`;
        }

        async function loadProfile() {
            if (!safeIsLoggedIn()) {
                window.location.href = '/login?redirect=/profile';
                return;
            }

            const user = safeGetCurrentUser() || {};
            const displayName = user.name || user.full_name || 'Guest User';
            document.getElementById('profileInitial').textContent = displayName.charAt(0).toUpperCase();
            document.getElementById('profileName').textContent = displayName;
            document.getElementById('profileRole').textContent = user.role === 'admin' ? 'Administrator' : 'Customer';
            document.getElementById('profileEmail').textContent = user.email || '-';
            document.getElementById('profilePhone').textContent = user.phone || '-';

            try {
                const result = await getUserBookings();
                const bookings = result.bookings || [];
                const today = new Date();

                document.getElementById('bookingCount').textContent = bookings.length;
                document.getElementById('cancelledCount').textContent = bookings.filter(booking => booking.status === 'cancelled').length;
                document.getElementById('upcomingCount').textContent = bookings.filter(booking => {
                    return booking.status !== 'cancelled' && new Date(booking.check_in) >= today;
                }).length;

                document.getElementById('profileBookings').innerHTML = bookings.length
                    ? bookings.map(booking => `
                        <tr>
                            <td>BK-${String(booking.id).padStart(3, '0')}</td>
                            <td>${booking.room_name || 'Room Not Available'}</td>
                            <td>${formatDate(booking.check_in)}</td>
                            <td>${formatDate(booking.check_out)}</td>
                            <td>₹${Number(booking.total_price || 0).toFixed(2)}</td>
                            <td>${statusBadge(booking.status)}</td>
                        </tr>
                    `).join('')
                    : '<tr><td colspan="6" class="text-center text-muted py-4">No bookings yet.</td></tr>';
            } catch (error) {
                document.getElementById('profileBookings').innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">Unable to load bookings.</td></tr>';
            }
        }

        document.getElementById('profileLogoutBtn').addEventListener('click', function () {
            localStorage.removeItem('token');
            localStorage.removeItem('user');
            localStorage.removeItem('adminToken');
            localStorage.removeItem('adminUser');
            window.location.href = '/';
        });

        document.addEventListener('DOMContentLoaded', loadProfile);
    </script>
</body>

</html>
