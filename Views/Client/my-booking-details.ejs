<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Hotelier - Booking Details</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <link href="/img/favicon.ico" rel="icon">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/lib/animate/animate.min.css" rel="stylesheet">
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet">

    <style>
        .detail-panel {
            background: #fff;
            border: 1px solid #eef1f5;
            border-radius: 8px;
            box-shadow: 0 8px 30px rgba(15, 23, 42, 0.06);
        }

        .detail-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1px;
            background: #eef1f5;
            border-radius: 8px;
            overflow: hidden;
        }

        .detail-cell {
            background: #fff;
            padding: 16px;
        }

        .timeline-item {
            display: flex;
            gap: 14px;
            padding-bottom: 20px;
        }

        .timeline-icon {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(243, 179, 61, 0.16);
            color: #f3b33d;
            flex: 0 0 auto;
        }

        @media (max-width: 767.98px) {
            .detail-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <div class="container-xxl bg-white p-0">
        <%- include('../partials/header', { currentPage: 'bookings' }) %>

        <div class="container-fluid page-header mb-5 p-0" style="background-image: url(/img/carousel-1.jpg);">
            <div class="container-fluid page-header-inner py-5">
                <div class="container text-center pb-5">
                    <h1 class="display-3 text-white mb-3 animated slideInDown">Booking Details</h1>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb justify-content-center text-uppercase">
                            <li class="breadcrumb-item"><a href="/">Home</a></li>
                            <li class="breadcrumb-item"><a href="/my-bookings">My Bookings</a></li>
                            <li class="breadcrumb-item text-white active" aria-current="page">Details</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>

        <div class="container-xxl py-5">
            <div class="container">
                <div id="detailsLoading" class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="sr-only">Loading...</span>
                    </div>
                    <p class="mt-3 text-muted">Loading booking details...</p>
                </div>

                <div id="detailsError" class="detail-panel text-center p-5 d-none">
                    <i class="fa fa-exclamation-triangle fa-3x text-danger mb-3"></i>
                    <h4 class="mb-2">Booking Not Found</h4>
                    <p class="text-muted mb-4" id="detailsErrorText">We could not load this booking.</p>
                    <a href="/my-bookings" class="btn btn-primary">Back to My Bookings</a>
                </div>

                <div id="detailsContent" class="d-none">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                        <div>
                            <p class="text-primary text-uppercase mb-2">Reservation</p>
                            <h2 class="mb-1" id="bookingReference">Booking Details</h2>
                            <p class="text-muted mb-0" id="bookingCreated">-</p>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <a href="/my-bookings" class="btn btn-outline-primary">
                                <i class="fa fa-arrow-left me-2"></i>All Bookings
                            </a>
                            <button class="btn btn-outline-danger d-none" id="cancelBookingBtn">
                                <i class="fa fa-times me-2"></i>Cancel Booking
                            </button>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-lg-8">
                            <div class="detail-panel p-4 mb-4">
                                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                                    <div>
                                        <h3 class="mb-1" id="roomName">Room</h3>
                                        <p class="text-muted mb-0" id="guestLine">Guest details</p>
                                    </div>
                                    <span id="statusBadge"></span>
                                </div>

                                <div class="detail-grid">
                                    <div class="detail-cell">
                                        <small class="text-muted d-block">Check In</small>
                                        <strong id="checkIn">-</strong>
                                    </div>
                                    <div class="detail-cell">
                                        <small class="text-muted d-block">Check Out</small>
                                        <strong id="checkOut">-</strong>
                                    </div>
                                    <div class="detail-cell">
                                        <small class="text-muted d-block">Guests</small>
                                        <strong id="guests">-</strong>
                                    </div>
                                    <div class="detail-cell">
                                        <small class="text-muted d-block">Nights</small>
                                        <strong id="nights">-</strong>
                                    </div>
                                </div>
                            </div>

                            <div class="detail-panel p-4">
                                <h5 class="mb-3"><i class="fa fa-user me-2 text-primary"></i>Guest Information</h5>
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <small class="text-muted d-block">Name</small>
                                        <strong id="guestName">-</strong>
                                    </div>
                                    <div class="col-md-4">
                                        <small class="text-muted d-block">Email</small>
                                        <strong id="guestEmail">-</strong>
                                    </div>
                                    <div class="col-md-4">
                                        <small class="text-muted d-block">Phone</small>
                                        <strong id="guestPhone">-</strong>
                                    </div>
                                </div>
                                <div class="mt-4" id="specialRequestBlock">
                                    <small class="text-muted d-block">Special Request</small>
                                    <p class="mb-0" id="specialRequest">-</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4">
                            <div class="detail-panel p-4 mb-4">
                                <h5 class="mb-3"><i class="fa fa-rupee-sign me-2 text-primary"></i>Price Details</h5>
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted">Rate per night</span>
                                    <strong id="ratePerNight">-</strong>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted">Subtotal</span>
                                    <strong id="subtotal">-</strong>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted">Tax (12%)</span>
                                    <strong id="tax">-</strong>
                                </div>
                                <hr>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold">Total Paid</span>
                                    <h4 class="text-primary mb-0" id="totalAmount">-</h4>
                                </div>
                            </div>

                            <div class="detail-panel p-4">
                                <h5 class="mb-3"><i class="fa fa-info-circle me-2 text-primary"></i>Stay Information</h5>
                                <div class="timeline-item">
                                    <span class="timeline-icon"><i class="fa fa-clock"></i></span>
                                    <div>
                                        <strong>Check-in Time</strong>
                                        <p class="text-muted mb-0">2:00 PM</p>
                                    </div>
                                </div>
                                <div class="timeline-item">
                                    <span class="timeline-icon"><i class="fa fa-door-open"></i></span>
                                    <div>
                                        <strong>Check-out Time</strong>
                                        <p class="text-muted mb-0">11:00 AM</p>
                                    </div>
                                </div>
                                <div class="timeline-item pb-0">
                                    <span class="timeline-icon"><i class="fa fa-id-card"></i></span>
                                    <div>
                                        <strong>Documents</strong>
                                        <p class="text-muted mb-0">Carry a valid government ID at check-in.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <%- include('../partials/footer') %>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="/js/config.js"></script>
    <script src="/js/api.js"></script>
    <script src="/js/auth.js"></script>
    <script>
        let activeBookingId = null;

        function setText(id, value) {
            const element = document.getElementById(id);
            if (element) element.textContent = value || '-';
        }

        function formatDate(value) {
            if (!value) return '-';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return '-';
            return date.toLocaleDateString(undefined, {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
            });
        }

        function money(value) {
            return `₹${Number(value || 0).toFixed(2)}`;
        }

        function calculateNights(checkIn, checkOut) {
            const start = new Date(checkIn);
            const end = new Date(checkOut);
            if (Number.isNaN(start.getTime()) || Number.isNaN(end.getTime())) return 0;
            return Math.max(Math.ceil((end - start) / (1000 * 60 * 60 * 24)), 1);
        }

        function statusBadge(status) {
            const normalized = String(status || 'pending').toLowerCase();
            const badgeClass = normalized === 'cancelled'
                ? 'danger'
                : normalized === 'confirmed'
                    ? 'success'
                    : normalized === 'completed'
                        ? 'info'
                        : 'warning';

            return `<span class="badge bg-${badgeClass} text-uppercase px-3 py-2">${normalized}</span>`;
        }

        function showState(state, message = '') {
            document.getElementById('detailsLoading').classList.toggle('d-none', state !== 'loading');
            document.getElementById('detailsError').classList.toggle('d-none', state !== 'error');
            document.getElementById('detailsContent').classList.toggle('d-none', state !== 'ready');
            if (message) setText('detailsErrorText', message);
        }

        function getBookingId() {
            const parts = window.location.pathname.split('/').filter(Boolean);
            return parts[parts.length - 1];
        }

        function renderBookingDetails(booking) {
            const nights = calculateNights(booking.check_in, booking.check_out);
            const ratePerNight = Number(booking.rate_per_night || 0);
            const subtotal = ratePerNight * nights;
            const tax = subtotal * 0.12;
            const total = Number(booking.total_price || 0) || subtotal + tax;
            const status = String(booking.status || 'pending').toLowerCase();

            activeBookingId = booking.id;
            setText('bookingReference', `Booking #HOT-${String(booking.id).padStart(5, '0')}`);
            setText('bookingCreated', `Booked on ${formatDate(booking.created_at)}`);
            setText('roomName', booking.room_name || 'Room Not Available');
            setText('guestLine', `${booking.guest_name || 'Guest'} | ${booking.guest_email || '-'}`);
            document.getElementById('statusBadge').innerHTML = statusBadge(status);

            setText('checkIn', formatDate(booking.check_in));
            setText('checkOut', formatDate(booking.check_out));
            setText('guests', `${Number(booking.guests || 0)} Guest(s)`);
            setText('nights', `${nights} Night(s)`);

            setText('guestName', booking.guest_name);
            setText('guestEmail', booking.guest_email);
            setText('guestPhone', booking.guest_phone);

            if (booking.special_requests) {
                setText('specialRequest', booking.special_requests);
            } else {
                document.getElementById('specialRequestBlock').classList.add('d-none');
            }

            setText('ratePerNight', money(ratePerNight));
            setText('subtotal', money(subtotal));
            setText('tax', money(tax));
            setText('totalAmount', money(total));

            document.getElementById('cancelBookingBtn').classList.toggle('d-none', status === 'cancelled' || status === 'completed');
        }

        async function loadBookingDetails() {
            if (!safeIsLoggedIn()) {
                window.location.href = `/login?redirect=${encodeURIComponent(window.location.pathname)}`;
                return;
            }

            const user = safeGetCurrentUser();
            if (!user || !user.email) {
                localStorage.removeItem('token');
                localStorage.removeItem('user');
                window.location.href = `/login?redirect=${encodeURIComponent(window.location.pathname)}`;
                return;
            }

            showState('loading');

            try {
                const bookingId = getBookingId();
                const response = await getBookingById(bookingId);
                const booking = response.booking || response;

                if (!booking || String(booking.guest_email || '').toLowerCase() !== String(user.email || '').toLowerCase()) {
                    showState('error', 'This booking does not belong to the current logged-in user.');
                    return;
                }

                renderBookingDetails(booking);
                showState('ready');
            } catch (error) {
                showState('error', error.message || 'Unable to load booking details.');
            }
        }

        document.getElementById('cancelBookingBtn').addEventListener('click', async function () {
            if (!activeBookingId || !confirm('Cancel this booking?')) return;

            try {
                await cancelBooking(activeBookingId);
                if (typeof toastr !== 'undefined') toastr.success('Booking cancelled successfully');
                await loadBookingDetails();
            } catch (error) {
                if (typeof toastr !== 'undefined') toastr.error(error.message || 'Unable to cancel booking');
            }
        });

        document.addEventListener('DOMContentLoaded', loadBookingDetails);
    </script>
</body>

</html>
